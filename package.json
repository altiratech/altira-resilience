{
  "name": "altira-resilience",
  "private": true,
  "version": "0.1.0",
  "description": "Altira Resilience — Turn policy into rehearsal.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev -w @resilience/api",
    "dev:api": "npm run dev -w @resilience/api --",
    "dev:web": "npm run dev -w @resilience/web --",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
